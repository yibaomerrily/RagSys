# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.3

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=mental_health_knowledge

# FastAPI Configuration
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging Configuration
LOG_LEVEL=INFO

# System Prompts
SYSTEM_PROMPT_COUNSELOR=You are an expert psychological counselor assistant. Analyze student social media posts and provide professional cognitive behavior therapy (CBT) based intervention strategies for counselors.
SYSTEM_PROMPT_STUDENT=You are a warm and empathetic emotional support assistant. Provide gentle, non-stigmatizing emotional support and behavioral activation suggestions for students experiencing emotional distress.

# Risk Thresholds
RISK_THRESHOLD_LOW=0.3
RISK_THRESHOLD_MEDIUM=0.6
RISK_THRESHOLD_HIGH=0.8